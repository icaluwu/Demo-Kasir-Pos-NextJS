# === Lokal (Docker): docker compose up -d ===
DATABASE_URL="postgresql://pos:pos@127.0.0.1:5432/demo_pos?schema=public"
# Wajib untuk Prisma directUrl — lokal: sama dengan DATABASE_URL
DATABASE_URL_UNPOOLED="postgresql://pos:pos@127.0.0.1:5432/demo_pos?schema=public"

# === Vercel + integrasi Neon ===
# Biasanya sudah otomatis: DATABASE_URL (pooled) + DATABASE_URL_UNPOOLED (direct).
# Jika hanya ada POSTGRES_URL_NON_POOLING, di Vercel tambahkan manual:
# DATABASE_URL_UNPOOLED = (nilai yang sama dengan POSTGRES_URL_NON_POOLING)

# Minimal 32 karakter — wajib unik di production (TIDAK diisi Neon otomatis)
SESSION_SECRET="ganti-dengan-string-panjang-minimal-32-karakter"

# Admin demo (ubah password setelah go-live)
ADMIN_USERNAME="IcalUwU"
ADMIN_PASSWORD="DemoPos123#"
