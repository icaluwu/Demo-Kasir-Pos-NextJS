# === Lokal (Docker): docker compose up -d ===
DATABASE_URL="postgresql://pos:pos@127.0.0.1:5432/demo_pos?schema=public"
# Wajib ada setelah pakai directUrl di schema Prisma — lokal: duplikat DATABASE_URL
DIRECT_URL="postgresql://pos:pos@127.0.0.1:5432/demo_pos?schema=public"

# === Vercel + Neon (contoh) ===
# DATABASE_URL  = connection string "pooled" / dengan -pooler (untuk runtime app)
# DIRECT_URL    = connection string "direct" tanpa pooler (untuk prisma db push / migrate)
# Keduanya dari dashboard Neon → Connection details.

# Minimal 32 karakter — wajib unik di production
SESSION_SECRET="ganti-dengan-string-panjang-minimal-32-karakter"

# Admin demo (ubah password setelah go-live)
ADMIN_USERNAME="IcalUwU"
ADMIN_PASSWORD="DemoPos123#"
